# ---------- Wallet ----------
# Required ONLY if AUTO_TRADE=true. Leave blank for print-only mode.
# Accepts a 24-word mnemonic (space-separated) or a 64-char hex raw key.
PRIVATE_KEY=

# ---------- RPC ----------
# Default TON RPC endpoint (used as fallback for CHAIN_RPC_TON)
RPC=https://toncenter.com/api/v2/jsonRPC

# ---------- Trading ----------
# GRAM (or chain's base token) amount per swap leg
TRADE_SIZE=10

# Minimum net profit % to trigger an alert (after fees + slippage)
MIN_PROFIT=1.5

# Slippage buffer % — subtracted from estimated profit AND used as the
# max acceptable slippage for safety checks
SLIPPAGE=0.5

# Per-position take-profit and stop-loss percentages (0 disables)
TAKE_PROFIT=0
STOP_LOSS=0

# Minimum pool liquidity (USD) below which opportunities are skipped
MIN_LIQUIDITY_USD=1000

# Jettons to consider for cross-DEX arbitrage (base_token -> jetton -> base_token)
INTERMEDIATE_JETTONS=USDT,DOGS,DUST,NOT,PX

# false = scan and print only. true = attempt on-chain execution.
AUTO_TRADE=false

# Seconds between scans (integer, min 1)
SCAN_INTERVAL=5

# ---------- Strategies ----------
# Comma-separated. Available: cross_dex, route, new_pair
STRATEGIES=cross_dex,route,new_pair

# ---------- Multi-chain ----------
# Comma-separated. Available: TON, Solana, Base, BNB
ENABLED_CHAINS=TON

# Per-chain base token (every trade starts and ends in this token)
CHAIN_BASE_TOKEN_TON=GRAM
CHAIN_BASE_TOKEN_SOLANA=SOL
CHAIN_BASE_TOKEN_BASE=ETH
CHAIN_BASE_TOKEN_BNB=BNB

# Per-chain RPC endpoints
CHAIN_RPC_TON=https://toncenter.com/api/v2/jsonRPC
CHAIN_RPC_SOLANA=https://api.mainnet-beta.solana.com
CHAIN_RPC_BASE=https://mainnet.base.org
CHAIN_RPC_BNB=https://bsc-dataseed.binance.org

# ---------- Telegram ----------
# Create a bot via @BotFather, then send it a message so it can write to you.
# Leave both empty to disable Telegram notifications entirely.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---------- Logging ----------
# Optional path to a log file. Empty = stdout only.
LOG_FILE=
